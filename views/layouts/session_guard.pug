script.
  (function() {
    var INACTIVIDAD_MS = 15 * 60 * 1000; // 15 min sin actividad
    var SUSPENSION_MS  = 15 * 60 * 1000; // 15 min en segundo plano / pantalla apagada

    function cerrarSesion() {
      window.location.replace('/auth/logout');
    }

    // ── 1. Botón ← Atrás / → Adelante ──────────────────────────────────────
    // Agrega un estado trampa. Al presionar ←, popstate intercepta
    // ANTES de que el navegador cambie de página y cierra sesión.
    // El usuario nunca vuelve a ver la interfaz protegida.
    history.pushState(null, '', window.location.href);
    window.addEventListener('popstate', function() {
      cerrarSesion();
    });

    // ── 2. Respaldo bfcache ─────────────────────────────────────────────────
    // Por si el navegador restaura desde bfcache antes de que popstate alcance.
    window.addEventListener('pageshow', function(e) {
      if (e.persisted) cerrarSesion();
    });

    // ── 3. Inactividad ──────────────────────────────────────────────────────
    // Si no hay actividad por INACTIVIDAD_MS, expira la sesión.
    var timer = setTimeout(cerrarSesion, INACTIVIDAD_MS);
    function resetTimer() {
      clearTimeout(timer);
      timer = setTimeout(cerrarSesion, INACTIVIDAD_MS);
    }
    ['mousemove','keydown','click','scroll','touchstart'].forEach(function(ev) {
      document.addEventListener(ev, resetTimer, { passive: true });
    });

    // ── 4. Suspensión larga (tab en segundo plano / pantalla apagada) ───────
    var ocultadoEn = null;
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) {
        ocultadoEn = Date.now();
      } else {
        if (ocultadoEn && (Date.now() - ocultadoEn) >= SUSPENSION_MS) {
          cerrarSesion();
        }
        ocultadoEn = null;
      }
    });
  })();
