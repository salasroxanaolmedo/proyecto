include ../layouts/main_layout
style.
    /* Estilos específicos para la vista de error denegado */
    .auth-section {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 60vh; /* Ajustado para que no desborde el layout */
      padding: 2rem;
    }

    .auth-container {
      width: 100%;
      max-width: 420px;
      background: #161616;
      border: 1px solid #252525;
      padding: 2.5rem;
      text-align: center;
      box-shadow: 0 20px 50px rgba(0,0,0,0.5);
      animation: fadeIn 0.5s ease both;
    }

    .lock-icon {
      font-size: 3rem;
      display: block;
      margin-bottom: 1rem;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      line-height: 1;
      margin: 0;
      color: #f0ede8;
    }

    .section-title-sub {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      color: #f0ede8;
      margin-bottom: 1rem;
    }

    .highlight { color: #e85d04; }

    .auth-subtitle {
      font-family: 'IBM Plex Mono', monospace;
      color: #7a7a7a;
      font-size: 0.85rem;
      margin-bottom: 2rem;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

.auth-section
  .auth-container
    .auth-header
      span(style="font-size: 3rem") 🔒
      h2.section-title
        | ACC
        span.highlight ESO
      h3.section-title DENEGADO
      p.auth-subtitle #{mensaje || 'No tienes permiso para ver esta página'}
    a.btn-primary(href="/auth/login") Volver al login