include ./layouts/main_layout.pug

block contenido
  style.
    :root {
      --negro: #0a0a0a;
      --gris-oscuro: #141414;
      --gris-acento: #2a2a2a;
      --naranja: #e85d04;
      --blanco: #f5f0e8;
      --borde: rgba(232, 93, 4, 0.25);
    }
    body { background-color: var(--negro); color: var(--blanco); font-family: Barlow, sans-serif; margin: 0; }
    .tickets-container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
    h1 { font-family: Bebas Neue, sans-serif; color: var(--blanco); text-align: center; letter-spacing: 2px; }
    .grid-tickets { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 30px; }
    .ticket-card { background: var(--gris-oscuro); border: 1px solid var(--borde); padding: 20px; border-radius: 6px; }
    .ticket-header { border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; margin-bottom: 15px; }
    .ticket-header h3 { margin: 0; color: var(--naranja); text-transform: uppercase; }
    .ticket-info p { margin: 5px 0; font-size: 0.9rem; color: #c9c0b0; }
    .ticket-info strong { color: var(--blanco); }
    .estatus-form { margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1); }
    select, button { width: 100%; padding: 10px; margin-top: 10px; background: var(--gris-acento); color: white; border: 1px solid var(--borde); cursor: pointer; outline: none; }
    button { background: var(--naranja); color: var(--negro); font-weight: bold; border: none; text-transform: uppercase; }
    .badge { display: inline-block; padding: 3px 8px; border-radius: 12px; font-size: 0.8rem; background: var(--gris-acento); color: white; border: 1px solid rgba(255,255,255,0.2); }

  // --- NAVBAR DEL EMPLEADO ---
  nav(style="display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; background: var(--gris-oscuro); border-bottom: 1px solid var(--borde);")
    a.navbar-brand(href="#" style="text-decoration: none; color: var(--blanco); font-family: Bebas Neue; font-size: 1.5rem;")
      span(style="color: var(--naranja); margin-right: 5px;") ⚙
      | Auto
      span(style="color: var(--naranja);") Taller Olmedo
    
    .nav-right(style="display: flex; align-items: center; gap: 20px;")
      .emp-info(style="text-align: right; line-height: 1.2;")
        if !empleado
          strong(style="display: block; color: var(--naranja);") Mecánico Desconocido
          span(style="font-size: 0.8rem; color: #c9c0b0;") Cargando perfil...
        else
          strong(style="display: block; color: var(--naranja);")= empleado.nombre
          span(style="font-size: 0.8rem; color: #c9c0b0;") Mecánico · ID-#{empleado.idCorto}
      
      a.btn-logout(href="/auth/login" style="color: var(--blanco); text-decoration: none; font-size: 0.8rem; border: 1px solid var(--borde); padding: 5px 10px;") ↩ Salir

  // --- CONTENIDO DE TICKETS ---
  .tickets-container
    h1 Mis Órdenes de Trabajo Asignadas
    
    if tickets && tickets.length > 0
      .grid-tickets
        each ticket in tickets
          .ticket-card
            .ticket-header
              h3 Vehículo: #{ticket.vehiculo || 'No especificado'}
              span.badge Placa: #{ticket.placa || 'N/A'}
            
            .ticket-info
              p #[strong Cliente:] #{ticket.perfiles ? ticket.perfiles.nombre : 'Sin registro'}
              p #[strong Servicio:] #{ticket.servicios ? ticket.servicios.nombre_servicio : 'Revisión General'}
              p #[strong Estado Actual:] #{ticket.estatus_servicio}
              p #[strong Ingreso:] #{new Date(ticket.created_at).toLocaleDateString()}
            
            .estatus-form
              form(action="/empleado/actualizar-ticket" method="POST")
                input(type="hidden" name="ticketId" value=ticket.id)
                label(style="font-size: 0.8rem; color: var(--naranja);") Actualizar Avance:
                select(name="nuevoEstatus")
                  option(value="Recibido" selected=ticket.estatus_servicio === 'Recibido') Recibido
                  option(value="En diagnóstico" selected=ticket.estatus_servicio === 'En diagnóstico') En diagnóstico
                  option(value="En reparación" selected=ticket.estatus_servicio === 'En reparación') En reparación
                  option(value="Pruebas de ruta" selected=ticket.estatus_servicio === 'Pruebas de ruta') Pruebas de ruta
                  option(value="Listo para entrega" selected=ticket.estatus_servicio === 'Listo para entrega') Listo para entrega
                button(type="submit") Guardar Cambios
    else
      p(style="text-align: center; color: var(--naranja); margin-top: 50px;") No tienes tickets de trabajo asignados en este momento.

