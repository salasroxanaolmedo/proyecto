include ./layouts/header2

block head
  title Recepción | AutoTaller Olmedo
  style.
    /* --- DISEÑO DE BUSCADOR PERSONALIZADO --- */
    .search-results-wrapper {
      position: absolute;
      z-index: 1000;
      width: 100%;
      top: 100%;
      background: #1a1a1a;
      border: 1px solid #333;
      border-top: none;
      max-height: 250px;
      overflow-y: auto;
      display: none;
      box-shadow: 0 10px 30px rgba(0,0,0,0.8);
      border-radius: 0 0 4px 4px;
    }
    .result-item {
      padding: 12px 15px;
      color: #eee;
      cursor: pointer;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.85rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: all 0.2s;
    }
    .result-item.is-active, .result-item:hover {
      background: #262626 !important;
      color: #ff6600 !important;
      border-left: 3px solid #ff6600;
      padding-left: 18px;
    }
    .iden-tag {
      font-size: 0.7rem;
      color: #666;
      background: #111;
      padding: 2px 6px;
      border-radius: 3px;
      text-transform: uppercase;
    }
    .token-input-group {
      display: flex;
      gap: 5px;
      align-items: center;
    }
    #btnRegenerar {
      background: #333;
      border: 1px solid #444;
      color: var(--naranja);
      padding: 8px 12px;
      cursor: pointer;
      border-radius: 4px;
      transition: background 0.2s;
    }
    /* ESTILOS VENTA RÁPIDA */
    .quick-actions { margin-bottom: 20px; display: flex; gap: 10px; }
    .btn-quick {
      flex: 1; padding: 12px; font-family: 'Bebas Neue'; font-size: 1.1rem;
      letter-spacing: 1px; cursor: pointer; border-radius: 4px; transition: 0.3s;
    }
    #btnVentaRapida { background: #1a1a1a; color: #ff6600; border: 1px solid #ff6600; }
    #btnModoTaller { background: #ff6600; color: #000; border: 1px solid #ff6600; display: none; }
    
    /* PRECIO DINÁMICO */
    .precio-tag {
      background: #111;
      color: var(--naranja);
      padding: 8px 12px;
      border-radius: 4px;
      font-family: 'Bebas Neue';
      font-size: 1.1rem;
      min-width: 90px;
      text-align: center;
      border: 1px solid #333;
    }

    /* ESTADO BLOQUEADO */
    .input-blocked { background: #0a0a0a !important; color: #888 !important; cursor: not-allowed !important; border-color: #222 !important; }

block contenido
  include ./layouts/header.pug

  .recepcion-container
    .form-card       
      .quick-actions
        button#btnVentaRapida.btn-quick(type="button")  VENTA RÁPIDA
        button#btnModoTaller.btn-quick(type="button")  VOLVER A MODO TALLER

      form(id="formRecepcion")
        input(type="hidden" name="id_cliente" id="in_id_cliente")
        fieldset#sectionCliente
          legend Registro de Cliente
          div#rowBusqueda(style="margin-bottom: 20px; position: relative;")
            label BUSCAR CLIENTE EN BASE DE DATOS:
            .filter-search(style="margin-bottom: 5px;")
              span.filter-icon ⌕
              input#txtBuscarCliente.input-dark(type="text", placeholder="Escriba nombre o identificación...", autocomplete="off")
            button#btnLimpiarCliente(type="button" style="display:none; background: #444; color: white; border: none; padding: 5px 10px; font-size: 0.7rem; margin-top: 5px; cursor: pointer; border-radius: 3px;") ✕ Cancelar selección / Nuevo Cliente
            div#resultsWrapper.search-results-wrapper

          .grid-3
            div#divNombre
              label.required Nombre Completo:
              input(type="text" name="nombre" id="in_nombre" required)
            div#divTelefono
              label Teléfono:
              input(type="tel" name="telefono" id="in_telefono" pattern="[0-9]*" maxlength="10")
            div#divIden
              label Tipo de Identificación:
              select(name="identificacion" id="in_identificacion")
                option(value="INE") INE
                option(value="PASAPORTE") PASAPORTE
                option(value="LICENCIA DE CONDUCIR") LICENCIA DE CONDUCIR
          
          hr#hrPortal(style="border: none; border-top: 1px solid rgba(255,255,255,0.05); margin: 20px 0;")
          
          div#txtPortal(style="color: var(--naranja); font-size: 0.7rem; font-weight: bold; margin-bottom: 10px; letter-spacing: 1px;") ACCESO AL PORTAL PARA EL CLIENTE
          .grid-2
            div#divEmail
              label.required Correo Electrónico:
              input(type="email" name="email" id="in_email" required)
            div#divPass
              label.required Contraseña:
              .token-input-group
                .pass-container(style="flex: 1;")
                  input(type="password" name="password" id="password" required style="background: #1a1a1a !important; color: var(--naranja) !important; cursor: text; letter-spacing: 2px;" placeholder="Asigne una contraseña")
                  span#togglePassword.pass-toggle
                    svg(width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                      path(d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z")
                      circle(cx="12" cy="12" r="3")
                      line#eyeSlash(x1="1" y1="1" x2="23" y2="23" style="opacity: 0; stroke: var(--naranja);")
                //button#btnRegenerar(type="button" title="Generar token") ↻

        fieldset#sectionVehiculo
          legend Información del Vehículo
          input(type="hidden" name="id_vehiculo" id="in_id_vehiculo" value="")

          div#vehiculosPreviosContainer(style="display:none; margin-bottom:15px;")
            label(style="color: var(--naranja)") Vehículos Registrados del Cliente:
            select#selectVehiculoPrevio(style="margin-bottom: 10px;" onchange="completarVehiculoPrevio()")
              option(value="")  Ingresar Vehículo Nuevo 
          
          .grid-3
            div
              label.required Marca y Modelo:
              input(type="text" name="vehiculo" id="in_vehiculo" required)
            div
              label.required Número de Placa:
              input(type="text" name="placa" id="in_placa" required style="text-transform: uppercase;")
            div
              label Año/Modelo:
              input(type="number" name="anio")
          .grid-3
            div
              label Kilometraje:
              input(type="number" name="kilometraje" id="in_km")
            div
              label Nivel de Combustible:
              select(name="nivel_combustible" id="in_gas")
                option 1/4 (Reserva)
                option 1/2 Tanque
                option 3/4 Tanque
                option Tanque Lleno
            div
              label Fecha y Hora de Entrada:
              - const date = new Date();
              - const localISO = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().slice(0,16);
              input(type="datetime-local" name="fecha_hora_llegada" id="in_fecha" value=localISO)

        fieldset#sectionOrden
          legend Orden de Servicio
          .grid-2
            div
              div#divServicio
                label Tipo de Servicio:
                select(name="id_servicio" id="selectServicio" onchange="calcular()")
                  option(value="" data-precio="0") Seleccione el Servicio 
                  if servicios
                    each s in servicios
                      option(value=s.id data-precio=s.precio_base) #{s.nombre_servicio}
              
              label(style="margin-top:15px") Insumos / Refacciones:
              div#productos-container
                div.producto-item(style="display: flex; gap: 10px; margin-bottom: 10px; align-items: center;")
                  select(name="id_producto" class="selectProducto" onchange="actualizarPrecioIndividual(this); calcular()" style="flex: 1")
                    option(value="" data-precio="0") Seleccionar producto 
                    if productos
                      each p in productos
                        option(value=p.id data-precio=p.precio_unitario) #{p.nombre_producto}
                  span.precio-tag $0.00
              button(type="button" onclick="agregarProducto()" style="background: var(--gris-acento); color: var(--naranja); border: 1px solid var(--borde); padding: 5px 10px; font-weight: bold; cursor: pointer; border-radius: 2px; font-size: 0.7rem; margin-top: 5px; width: auto;") + Agregar otro insumo
            
            div.total-box
              p(style="margin: 0; font-size: 0.8rem; letter-spacing: 1px;") PRESUPUESTO INICIAL
              span#displayTotal $0.00
              div#divMecanico
                label(style="color: white; margin-top: 10px; text-align: left;") Asignar a Mecánico:
                select(name="id_empleado_asignado" id="selectMecanico")
                  if empleados
                    each e in empleados
                      option(value=e.id) #{e.nombre} - #{e.especialidad}

        fieldset#sectionInspeccion
          legend Inspección Visual Inicial
          .grid-3
            label(style="display: flex; align-items: center; cursor: pointer; text-transform: none;")
              input(type="checkbox" name="ck_luces" id="ck_luces" style="width: auto; margin-right: 8px;")
              | Sistema Eléctrico OK
            label(style="display: flex; align-items: center; cursor: pointer; text-transform: none;")
              input(type="checkbox" name="ck_golpes" id="ck_golpes" style="width: auto; margin-right: 8px;")
              | Carrocería sin daños
            label(style="display: flex; align-items: center; cursor: pointer; text-transform: none;")
              input(type="checkbox" name="ck_limpieza" id="ck_limpieza" style="width: auto; margin-right: 8px;")
              | Interiores impecables
          textarea(name="notas" id="in_notas" placeholder="Observaciones de recepción..." style="width: 100%; height: 80px; margin-top: 15px;")

        .acciones(style="text-align: right; margin-top: 20px;")
          button(type="button" onclick="imprimirTicket()" class="btn-print" style="margin-right: 10px;") 🖨️ Imprimir Ticket
          button(type="submit" class="btn-guardar") Generar Orden

  include ./layouts/footer.pug

  // MODALES
  div#modalExito.modal-exito(style="display: none;")
    div.modal-content
      div.check-icon ✔
      h2(style="color: var(--naranja); font-family: 'Bebas Neue';") ¡REGISTRO EXITOSO!
      p Guardando información en el sistema...
      
  div#modalError.modal-exito(style="display: none;")
    div.modal-content(style="border-top: 4px solid #ff4444;")
      div.check-icon(style="color: #ff4444; border-color: #ff4444;") ✕
      h2(style="color: #ff4444; font-family: 'Bebas Neue'; letter-spacing: 2px;") ¡ATENCIÓN!
      p#mensajeError Texto del error...
      button.btn-cerrar-modal(type="button" onclick="cerrarModalError()") ENTENDIDO

  // TICKET DINÁMICO
  div#ticket(style="display:none; font-family: 'Courier New', Courier, monospace; width: 300px; padding: 10px; color: black;")
    center
      h2(style="margin: 0;") AUTOTALLER OLMEDO
      p#t_subtitulo(style="margin: 5px 0; font-size: 0.9rem;") TICKET DE VENTA (MOSTRADOR)
    hr(style="border: 1px solid black;")
    div(style="font-size: 0.85rem;")
      p(style="margin: 5px 0;") #[strong CLIENTE:] <br><span id="t_nombre">---</span>
      div#t_bloque_vehiculo
        p(style="margin: 5px 0;") #[strong VEHÍCULO:] <br><span id="t_vehiculo">---</span>
        p(style="margin: 5px 0;") #[strong PLACA:] <br><span id="t_m_placa">---</span>
      p(style="margin: 5px 0;") #[strong ATENDIÓ:] <br><span id="t_recepcionista">---</span>
      
      hr(style="border: 1px dashed black; margin: 10px 0;")
      center #[strong DETALLE DE VENTA]
      div#t_detalle_items(style="margin-top: 10px;")

      div#t_bloque_portal(style="margin-top: 15px;")
        hr(style="border: 1px dashed black;")
        center
          p(style="font-size: 0.75rem; margin: 5px 0;") ACCESO PORTAL CLIENTES
          p(style="margin: 2px 0;") #[strong USER:] <br><span id="t_user">---</span>
          p(style="margin: 2px 0;") #[strong PASS:] <br><span id="t_pass">---</span>
      
      hr(style="border: 1px solid black; margin: 10px 0;")
      div(style="text-align: right;")
        span(style="font-size: 1rem; font-weight: bold;") TOTAL: 
        span#t_total(style="font-size: 1.2rem; font-weight: bold;") $0.00
    
    center(style="margin-top: 20px;")
      p(style="font-size: 0.8rem;") ¡Gracias por su preferencia!

  script.
    const form = document.getElementById('formRecepcion');
    const inPass = document.getElementById('password');
    const inEmail = document.getElementById('in_email');
    const inNombre = document.getElementById('in_nombre');
    const inTelefono = document.getElementById('in_telefono');
    const selS = document.getElementById('selectServicio');
    const dispT = document.getElementById('displayTotal');
    const inPlaca = document.getElementById('in_placa');
    
    // --- ELEMENTOS DEL BUSCADOR ---
    const txtBus = document.getElementById('txtBuscarCliente');
    const wrapper = document.getElementById('resultsWrapper');
    const eyeSlash = document.getElementById('eyeSlash');
    const togglePassword = document.getElementById('togglePassword');
    const btnRegenerar = document.getElementById('btnRegenerar');
    const btnLimpiar = document.getElementById('btnLimpiarCliente'); // Botón de cancelar

    const nombreEmpleadoGlobal = "#{empleado ? empleado.nombre : 'Personal de Recepción'}";
    const clientesBase = !{JSON.stringify(clientes || [])};

    function generarToken(longitud = 6) {
      const caracteres = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      let resultado = '';
      for (let i = 0; i < longitud; i++) {
        resultado += caracteres.charAt(Math.floor(Math.random() * caracteres.length));
      }
      return resultado;
    }

    // --- FUNCIÓN PARA REGRESAR A MODO CLIENTE NUEVO ---
    function resetearAClienteNuevo() {
        document.getElementById('in_id_cliente').value = ""; 
        inNombre.value = "";
        inTelefono.value = "";
        inEmail.value = "";
        inPass.value = "";
        txtBus.value = "";
        
        // Mostrar campos de contraseña y habilitar requeridos
        document.getElementById('divPass').style.display = 'block';
        inPass.setAttribute('required', 'required');
        
        // Ocultar botón de limpiar
        if(btnLimpiar) btnLimpiar.style.display = 'none';
    }

    if(btnLimpiar) btnLimpiar.onclick = resetearAClienteNuevo;

    // --- LÓGICA DEL OJITO ---
    if (togglePassword) {
      togglePassword.onclick = function() {
        const isPassword = inPass.getAttribute('type') === 'password';
        inPass.setAttribute('type', isPassword ? 'text' : 'password');
        eyeSlash.style.opacity = isPassword ? '1' : '0';
      };
    }

    // --- LÓGICA REGENERAR MANUAL ---
    if (btnRegenerar) {
      btnRegenerar.onclick = () => {
        inPass.value = generarToken();
        inPass.setAttribute('type', 'text');
        eyeSlash.style.opacity = '1';
      };
    }

    // --- BUSCADOR ACTUALIZADO ---
    txtBus.addEventListener('input', function() {
      const term = this.value.toLowerCase();
      wrapper.innerHTML = '';
      if (term.length < 1) { wrapper.style.display = 'none'; return; }

      const filtrados = clientesBase.filter(c => 
        (c.nombre && c.nombre.toLowerCase().includes(term)) || 
        (c.identificacion && c.identificacion.toLowerCase().includes(term)) ||
        (c.usuario_acceso && c.usuario_acceso.toLowerCase().includes(term))
      );

      if (filtrados.length > 0) {
        filtrados.forEach((c) => {
          const item = document.createElement('div');
          item.className = 'result-item';
          item.innerHTML = `
            <div style="display:flex; flex-direction:column; text-align: left;">
              <span style="font-weight: bold;">${c.nombre}</span>
              <span style="font-size: 0.75rem; color: #ff6600;">✉ ${c.usuario_acceso || 'Sin correo registrado'}</span>
            </div>
            <span class="iden-tag">${c.identificacion || 'S/N'}</span>
          `;
          
          // ESTA ES LA PARTE QUE BUSCABAS:
          item.onclick = () => {
            // 1. Guardar ID y llenar campos
            document.getElementById('in_id_cliente').value = c.id; 
            inNombre.value = c.nombre;
            inTelefono.value = c.telefono || "";
            document.getElementById('in_identificacion').value = (c.identificacion || "INE").toUpperCase();
            inEmail.value = c.usuario_acceso || "";
            
            // Mostrar también el correo en el buscador una vez seleccionado
            txtBus.value = c.usuario_acceso ? `${c.nombre} (${c.usuario_acceso})` : c.nombre;

            // 2. Ocultar sección de contraseña
            document.getElementById('divPass').style.display = 'none';
            inPass.removeAttribute('required');
            inPass.value = "VALOR_EXISTENTE"; 

            // 3. Mostrar botón para poder revertir/limpiar
            if(btnLimpiar) btnLimpiar.style.display = 'inline-block';

            // 4. Llenar u Ocultar Vehículos del Cliente
            const vehContainer = document.getElementById('vehiculosPreviosContainer');
            const selVeh = document.getElementById('selectVehiculoPrevio');
            selVeh.innerHTML = '<option value="">-- Ingresar Vehículo Nuevo --</option>'; // Reset
            
            if (c.vehiculos && c.vehiculos.length > 0) {
                vehContainer.style.display = 'block';
                c.vehiculos.forEach((v, index) => {
                    const opt = document.createElement('option');
                    opt.value = index;
                    opt.text = `${v.placa.toUpperCase()} - ${v.modelo || 'Vehículo'}`;
                    opt.dataset.modelo = v.modelo || "";
                    opt.dataset.placa = v.placa || "";
                    opt.dataset.anio = v.anio || "";
                    opt.dataset.idvehiculo = v.id || "";
                    selVeh.appendChild(opt);
                });
                // Autocompletar con el primer vehículo por defecto
                selVeh.selectedIndex = 1;
                completarVehiculoPrevio();
            } else {
                vehContainer.style.display = 'none';
                document.getElementById('in_vehiculo').value = '';
                document.getElementById('in_placa').value = '';
                document.querySelector('input[name="anio"]').value = '';
            }

            wrapper.style.display = 'none';
          };
          wrapper.appendChild(item);
        });
        wrapper.style.display = 'block';
      } else {
        wrapper.style.display = 'none';
      }
    });

    // --- LOGICA DE AUTOCOMPLETADO DE VEHICULOS ---
    function completarVehiculoPrevio() {
      const selVeh = document.getElementById('selectVehiculoPrevio');
      const vInput = document.getElementById('in_vehiculo');
      const pInput = document.getElementById('in_placa');
      const aInput = document.querySelector('input[name="anio"]');
      const idInput = document.getElementById('in_id_vehiculo');
      
      if (selVeh.value === "") {
          // Limpiar para vehículo nuevo
          vInput.value = '';
          pInput.value = '';
          aInput.value = '';
          idInput.value = '';
          
          vInput.readOnly = false;
          pInput.readOnly = false;
          vInput.classList.remove('input-blocked');
          pInput.classList.remove('input-blocked');
      } else {
          // Rellenar con los datos seleccionados
          const opt = selVeh.options[selVeh.selectedIndex];
          vInput.value = opt.dataset.modelo;
          pInput.value = opt.dataset.placa;
          aInput.value = opt.dataset.anio;
          idInput.value = opt.dataset.idvehiculo;
          
          // Bloquear campos para que no editen un coche existente (opcional pero recomendado)
          vInput.readOnly = true;
          pInput.readOnly = true;
          vInput.classList.add('input-blocked');
          pInput.classList.add('input-blocked');
      }
    }

    // --- MANTENIMIENTO DE CÁLCULOS ---
    function actualizarPrecioIndividual(selectElement) {
        const precio = parseFloat(selectElement.options[selectElement.selectedIndex]?.dataset.precio) || 0;
        const tag = selectElement.parentElement.querySelector('.precio-tag');
        if(tag) tag.innerText = `$${precio.toLocaleString('es-MX', {minimumFractionDigits: 2})}`;
    }

    function calcular() {
      const p1 = parseFloat(selS.options[selS.selectedIndex]?.dataset.precio) || 0;
      let sumaProd = 0;
      document.querySelectorAll('.selectProducto').forEach(s => {
          sumaProd += parseFloat(s.options[s.selectedIndex]?.dataset.precio) || 0;
      });
      dispT.innerText = `$${(p1 + sumaProd).toLocaleString('es-MX', {minimumFractionDigits: 2})}`;
    }

    function agregarProducto() {
      const container = document.getElementById('productos-container');
      const items = container.querySelectorAll('.producto-item');
      const base = items[0];
      const nuevo = base.cloneNode(true);
      nuevo.querySelector('select').value = ""; 
      nuevo.querySelector('.precio-tag').innerText = "$0.00";
      container.appendChild(nuevo);
    }

    // --- BOTONES DE MODO ---
    const btnVR = document.getElementById('btnVentaRapida');
    const btnMT = document.getElementById('btnModoTaller');

    btnVR.onclick = () => {
      inNombre.value = "CLIENTE MOSTRADOR";
      inEmail.value = "mostrador@autotallerolmedo.com";
      inPass.value = "MOSTRADOR123"; 
      document.getElementById('in_vehiculo').value = "VENTA MOSTRADOR";
      document.getElementById('in_placa').value = "MOSTRADOR";
      
      inNombre.readOnly = true; inEmail.readOnly = true; inPass.readOnly = true;
      inNombre.classList.add('input-blocked'); inEmail.classList.add('input-blocked'); inPass.classList.add('input-blocked');

      document.getElementById('divTelefono').style.display = 'none';
      ['sectionVehiculo', 'sectionInspeccion', 'divIden', 'divServicio', 'divMecanico', 'rowBusqueda', 'divPass', 'txtPortal', 'hrPortal'].forEach(id => {
        const el = document.getElementById(id);
        if(el) el.style.display = 'none';
      });
      btnVR.style.display = "none"; btnMT.style.display = "block";
    };

    btnMT.onclick = () => {
      form.reset();
      resetearAClienteNuevo(); // Limpiamos rastro de clientes buscados
      inNombre.readOnly = false; inEmail.readOnly = false; inPass.readOnly = false;
      inNombre.classList.remove('input-blocked'); inEmail.classList.remove('input-blocked'); inPass.classList.remove('input-blocked');
      document.getElementById('divTelefono').style.display = 'block';
      ['sectionVehiculo', 'sectionInspeccion', 'divIden', 'divServicio', 'divMecanico', 'rowBusqueda', 'divPass', 'txtPortal', 'hrPortal'].forEach(id => {
        const el = document.getElementById(id);
        if(el) el.style.display = '';
      });
      btnVR.style.display = "block"; btnMT.style.display = "none";
      document.querySelectorAll('.precio-tag').forEach(t => t.innerText = "$0.00");
      dispT.innerText = "$0.00";
    };

    function cerrarModalError() { document.getElementById('modalError').style.display = 'none'; }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      try {
        const response = await fetch('/recepcion', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const res = await response.json();
        if (!response.ok) {
          document.getElementById('mensajeError').innerText = res.message;
          document.getElementById('modalError').style.display = 'flex';
          return;
        }
        document.getElementById('modalExito').style.display = 'flex';
        setTimeout(() => { window.location.href = '/recepcion?exito=true'; }, 1500);
      } catch (err) { console.error(err); }
    });

    function imprimirTicket() {
      const esRapida = inNombre.value === "CLIENTE MOSTRADOR";
      const tDetalle = document.getElementById('t_detalle_items');
      tDetalle.innerHTML = '';
      if (!esRapida && selS.value !== "") {
        const servNombre = selS.options[selS.selectedIndex].text;
        const servPrecio = parseFloat(selS.options[selS.selectedIndex].dataset.precio).toFixed(2);
        tDetalle.innerHTML += `<p style="margin:2px 0;">${servNombre}<br><strong>$${servPrecio}</strong></p>`;
      }
      document.querySelectorAll('.selectProducto').forEach(s => {
        if (s.value !== "") {
          const prodNombre = s.options[s.selectedIndex].text;
          const prodPrecio = parseFloat(s.options[s.selectedIndex].dataset.precio).toFixed(2);
          tDetalle.innerHTML += `<p style="margin:2px 0;">${prodNombre}<br><strong>$${prodPrecio}</strong></p>`;
        }
      });
      document.getElementById('t_nombre').innerText = inNombre.value || "---";
      document.getElementById('t_total').innerText = dispT.innerText;
      document.getElementById('t_recepcionista').innerText = nombreEmpleadoGlobal;
      if (esRapida) {
        document.getElementById('t_subtitulo').innerText = "TICKET DE VENTA (MOSTRADOR)";
        document.getElementById('t_bloque_vehiculo').style.display = 'none';
        document.getElementById('t_bloque_portal').style.display = 'none';
      } else {
        document.getElementById('t_subtitulo').innerText = "ORDEN DE SERVICIO";
        document.getElementById('t_bloque_vehiculo').style.display = 'block';
        document.getElementById('t_bloque_portal').style.display = 'block';
        document.getElementById('t_vehiculo').innerText = document.getElementById('in_vehiculo').value;
        document.getElementById('t_m_placa').innerText = inPlaca.value.toUpperCase();
        document.getElementById('t_user').innerText = inEmail.value;
        document.getElementById('t_pass').innerText = inPass.value;
      }
      window.print();
    }

    document.addEventListener('click', (e) => { 
      if (!txtBus.contains(e.target)) wrapper.style.display = 'none'; 
    });